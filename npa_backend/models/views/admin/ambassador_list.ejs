<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ambassador Registrations - Admin</title>
  <style>
    body { font-family: system-ui, -apple-system, sans-serif; background: #f0fdf4; margin: 0; padding: 20px; color: #1e293b; }
    .container { max-width: 1200px; margin: 0 auto; }
    h1 { margin-bottom: 20px; color: #052e16; }
    .nav { margin-bottom: 20px; }
    .nav a { text-decoration: none; color: #16a34a; font-weight: 500; }
    .nav a:hover { text-decoration: underline; }
    table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
    th, td { padding: 12px 15px; text-align: left; border-bottom: 1px solid #dcfce7; }
    th { background: #f0fdf4; font-weight: 600; color: #166534; }
    tr:hover { background: #f8fafc; }
    .file-link { color: #16a34a; text-decoration: none; font-size: 0.9em; margin-right: 8px; }
    .file-link:hover { text-decoration: underline; }
    .empty { text-align: center; padding: 40px; color: #64748b; font-style: italic; }
    .badge { display: inline-block; padding: 4px 8px; border-radius: 4px; font-size: 0.85em; font-weight: 500; }
    .badge-sponsor { background: #dbeafe; color: #1e40af; }
    .badge-mentor { background: #fef3c7; color: #92400e; }
    .badge-volunteer { background: #dcfce7; color: #166534; }
    .badge-default { background: #e2e8f0; color: #475569; }
  </style>
</head>
<body>
  <div class="container">
    <div class="nav"><a href="/admin">← Back to Dashboard</a></div>
    <h1>🤝 Ambassador Registrations (<%= data.length %>)</h1>
    
    <% if (data.length === 0) { %>
      <div class="empty">No Ambassador registrations found yet.</div>
    <% } else { %>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Organization</th>
            <th>Position</th>
            <th>Type</th>
            <th>Support</th>
            <th>Commitment</th>
            <th>Files</th>
            <th>Registered</th>
          </tr>
        </thead>
        <tbody>
          <% data.forEach(d => { %>
            <tr>
              <td><strong><%= d.fullName %></strong></td>
              <td><%= d.email || '-' %></td>
              <td><%= d.organization || '-' %></td>
              <td><%= d.position || '-' %></td>
              <td>
                <% if (d.ambassadorType) { %>
                  <span class="badge badge-<%= d.ambassadorType.toLowerCase().replace(/\s+/g, '-') || 'default' %>"><%= d.ambassadorType %></span>
                <% } else { %> - <% } %>
              </td>
              <td><%= d.supportType || '-' %></td>
              <td><%= d.commitment || '-' %></td>
              <td>
                <% if (d.passport) { %><a href="<%= d.passport %>" target="_blank" class="file-link">Passport</a><% } %>
                <% if (d.supportingDoc) { %><a href="<%= d.supportingDoc %>" target="_blank" class="file-link">Doc</a><% } %>
                <% if (!d.passport && !d.supportingDoc) { %>-<% } %>
              </td>
              <td><small><%= new Date(d.registeredAt).toLocaleDateString() %></small></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>